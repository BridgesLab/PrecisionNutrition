 year      = "2024",
 issn      = "2090-0724",
 journal   = "Journal of Nutrition &amp; Metabolism",
 keywords  = "Bone density; Dietary calcium; Alkaline phosphatase; Image analysis; Three-dimensional imaging",
 pages     = "1-10",
