@article{18776452820250905,
 abstract  = "Objective: To investigate the association between thyroid hormone sensitivity indices and bone metabolism markers in newly diagnosed middle-aged and elderly type 2 diabetes mellitus (T2DM) patients with normal thyroid function. Method: We retrospectively analyzed 350 newly diagnosed T2DM patients (≥ 45 years), stratified by bone mineral density into Group A (normal bone density group) and Group B (low bone mass and osteoporosis group). General data and clinical biochemical parameters were collected: free triiodothyronine (FT3), free thyroxine (FT4), thyroid-stimulating hormone (TSH), 25-hydroxyvitamin D (25(OH)D), parathyroid hormone (PTH), osteocalcin (OC), bone-specific alkaline phosphatase (BALP), serum calcium (Ca), serum phosphorus (P), fasting plasma glucose (FPG), glycosylated hemoglobinA1c (HbA1c), total cholesterol (TC), triglyceride (TG), low-density lipoprotein cholesterol (LDL-C), high-density lipoprotein cholesterol (HDL-C), serum creatinine (SCr), serum uric acid (SUA), ",
 author    = "Fang, Lixuan and Lin, Cuiping and Gu, Lijuan and Zeng, Haixia and Zhang, Yuying and Liu, Jianping",
 number    = "1",
 title     = "Correlation between thyroid sensitivity indices and bone metabolism in newly diagnosed middle aged and elderly patients with type 2 diabetes mellitus with normal thyroid function.",
 volume    = "25",
 url       = "https://research.ebsco.com/linkprocessor/plink?id=504f41bd-99ea-3380-9312-ca2fc4ab8b13",
 year      = "2025",
 issn      = "1472-6823",
 journal   = "BMC Endocrine Disorders",
 keywords  = "Thyroid Hormones Blood; Bone and Bones Metabolism; Diabetes Mellitus, Type 2 Diagnosis; Disease Duration In Old Age; Bone Density; Human; Male; Female; Middle Age; Aged; Retrospective Design; Record Review; Diabetic Patients; Osteoporosis; Triiodothyronine; Thyroxine; Thyrotropin; Calcitriol; Parathyroid Hormones; Osteocalcin; Alkaline Phosphatase; Calcium Blood; Phosphorus Blood; Glycemic Index; Glycated Hemoglobin; Cholesterol Blood; Triglycerides Blood; Lipoproteins, LDL Cholesterol Blood; Lipoproteins, HDL Cholesterol Blood; Creatinine Blood; Uric Acid Blood; Glomerular Filtration Rate; Multiple Linear Regression; Logistic Regression; Body Mass Index; Age Factors; Spearman's Rank Correlation Coefficient; Sex Factors; T-Tests; Mann-Whitney U Test; Chi Square Test; Pearson's Correlation Coefficient; Confidence Intervals; ROC Curve; Funding Source; Sensitivity and Specificity; Cross Sectional Studies; Absorptiometry, Photon; Hip Radiography; Lumbar Vertebrae Radiography; Spine Radiography; Data Analysis Software; Descriptive Statistics; Middle Aged: 45-64 years; Aged: 65+ years; Male; Female",
 pages     = "1-12",
 note      = "",
