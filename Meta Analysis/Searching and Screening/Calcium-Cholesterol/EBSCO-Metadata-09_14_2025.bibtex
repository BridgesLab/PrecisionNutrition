 number    = "7",
 title     = "Assessment of serum calcium, magnesium and zinc levels in patients with type 2 diabetes mellitus in the Ukrainian population.",
 volume    = "19",
 url       = "https://research.ebsco.com/linkprocessor/plink?id=da5dc387-6974-3a69-bc49-3a5b40790a16",
 year      = "2023",
 issn      = "2224-0721",
 journal   = "International Journal of Endocrinology / Mìžnarodnij Endokrinologìčnij Žurnal",
 keywords  = "",
 pages     = "505-509",
