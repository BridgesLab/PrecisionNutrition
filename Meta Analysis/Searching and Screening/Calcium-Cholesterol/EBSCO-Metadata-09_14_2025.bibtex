@article{13352015020181201,
 abstract  = "Background: In clinical practice, abnormal biochemical changes often occur in women who eventually develop preeclampsia (PE). The study aims to investigate whether maternal serum biochemical markers in the early third trimester can predict PE and neonatal birth weight. Study Design: A retrospective case–control study was performed on 287 women who subsequently developed PE (mild = 139; severe = 148) and 143 healthy women. Fasting venous blood samples of all gravidas were drawn for routine biochemical markers screening in the early third trimester (28.49 ± 1.63 weeks). Appropriate statistical methods were selected for analysis with SPSS software. Results: (1) The concentrations of plasma triglyceride (TG), low-density lipoprotein cholesterol (LDL), and uric acid (UA) in the severe and mild subgroups of the PE group were significantly higher compared with the respective levels in the normal pregnancy groups (3.90 vs. 4.03 vs. 3.14 mmol/L; 3.41 vs. 3.33 vs. 2.89 mmol/L; 365.42 vs. 318.91",
 author    = "Sun, Li-Juan and Xu, Gu-Feng and Lv, Min and Zhou, Hao and Luo, Qiong and Huang, He-Feng",
 number    = "12",
 title     = "Predictive Value of Maternal Serum Biomarkers for Preeclampsia and Birth Weight: A Case–Control Study in Chinese Pregnant Women.",
 volume    = "27",
 url       = "https://research.ebsco.com/linkprocessor/plink?id=64cb6766-c654-387d-8b9f-49f60d321ab2",
 year      = "2018",
 issn      = "1540-9996",
 journal   = "Journal of Women's Health (15409996)",
 keywords  = "China; Risk factors of preeclampsia; Biomarkers; Birth weight; Calcium; Fasting; Low density lipoproteins; Third trimester of pregnancy; Triglycerides; Uric acid; Homocysteine; Predictive tests; Retrospective studies; Case-control method; Receiver operating characteristic curves; Data analysis software; Pregnancy",
 pages     = "1519-1524",
 note      = "",
}

@article{15166720320210901,
 abstract  = "The transition period (3 weeks before to 3 weeks after parturition) is a pivotal time in the life of a dairy cow when they face tremendous metabolic and physiologic changes. It is of importance to notice the dynamic changes in metabolites and lipid profile of indigenous parturient Sahiwal cows for rational managemental intervention during the periparturient period. Remarkable alterations in serum metabolites (calcium, glucose, urea and creatinine) enzymes activities (aspartate aminotransferase and alkaline phosphatase) and lipid contents (total cholesterol, triglyceride, high-density lipoprotein cholesterol and low-density lipoprotein cholesterol and very low-density lipoprotein) were recorded during the transition period of parturient Sahiwal cows. Albeit, parturient Sahiwal cows are predisposed to negative energy balance and hypocalcemia for few weeks post-partum, they have a quicker metabolic adaptive potential to recoup the altered metabolites and lipids dynamics.",
 author    = "Yadav, Brajesh K. and Singh, Vivek K. and Singh, Shanker K.",
 number    = "9",
 title     = "Lipid mobilization and serum metabolites dynamics of Sahiwal cows during the transition period.",
 volume    = "52",
 url       = "https://research.ebsco.com/linkprocessor/plink?id=d9c26492-2210-38b2-81cc-875a21024fd5",
 year      = "2021",
 issn      = "0929-1016",
 journal   = "Biological Rhythm Research",
 keywords  = "LDL cholesterol; HDL cholesterol; Blood lipids; Cholesterol content of food; Metabolites; Cows",
 pages     = "1364-1371",
 note      = "",
}

@article{17408676620231001,
 abstract  = "Background. The research deals with the provision of calcium, magnesium and zinc in patients with type 2 diabetes mellitus (T2DM). The purpose was to investigate the serum content of calcium, magnesium and zinc in patients with type 2 DM. Materials and methods. The open-label controlled study included 27 patients with T2DM. The control group consisted of 12 people without endocrine and somatic diseases. 70 % of patients had newly diagnosed DM; in others, the disease duration was up to 5 years. Most of the examined were of mature age, on average 61.83 ± 5.52 years for patients and 55.25 ± 5.52 years for controls. In the group with T2DM, women accounted for 62.96 %, among controls — 63.64 %. Anthropometric measurements and glucose indicators were determined according to a standard procedure. Concentrations of calcium, magnesium, zinc in serum were evaluated by atomic optical emission spectrometry with inductively coupled plasma (PerkinElmer Optima 2100 DV ICP-OES, USA) according to the ",
